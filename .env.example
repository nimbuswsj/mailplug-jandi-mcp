# Mailplug credentials. Copy this file to .env and fill real values locally only.
MAILPLUG_EMAIL=your-mailbox@example.com
MAILPLUG_APP_PASSWORD=replace-with-mailplug-app-password
MAILPLUG_POP3_HOST=pop3.mailplug.co.kr
MAILPLUG_POP3_PORT=995
MAILPLUG_SMTP_HOST=smtp.mailplug.co.kr
MAILPLUG_SMTP_PORT=465

# JANDI Incoming Webhook. Replace only in .env, never in committed files.
JANDI_WEBHOOK_URL=https://wh.jandi.com/connect-api/webhook/<generated-webhook-token>

# Public MCP URL planned for the Apache vhost.
MCP_PUBLIC_URL=https://mcp.nimbustech.co.kr/mcp

# Future HTTP deployment port. The current scaffold runs MCP over stdio.
MCP_HTTP_PORT=8710
