# 예시 전용입니다. 승인, DNS 확인, certificate 설정 전에는 enable하지 마세요.
# 의도한 backend: 127.0.0.1:8710에 bind된 MCP HTTP server.

<VirtualHost *:80>
    ServerName mcp.nimbustech.co.kr

    Alias /.well-known/acme-challenge/ /var/www/letsencrypt/.well-known/acme-challenge/
    <Directory /var/www/letsencrypt/.well-known/acme-challenge/>
        Options None
        AllowOverride None
        Require all granted
    </Directory>

    RewriteEngine On
    RewriteCond %{REQUEST_URI} !^/\.well-known/acme-challenge/
    RewriteRule ^ https://%{SERVER_NAME}%{REQUEST_URI} [END,NE,R=permanent]
</VirtualHost>

<IfModule mod_ssl.c>
<VirtualHost *:443>
    ServerName mcp.nimbustech.co.kr

    ProxyPreserveHost On
    ProxyPass / http://127.0.0.1:8710/
    ProxyPassReverse / http://127.0.0.1:8710/
    RequestHeader set X-Forwarded-Proto "https"
    RequestHeader set X-Forwarded-Port "443"

    Include /etc/letsencrypt/options-ssl-apache.conf
    SSLCertificateFile /etc/letsencrypt/live/mcp.nimbustech.co.kr/fullchain.pem
    SSLCertificateKeyFile /etc/letsencrypt/live/mcp.nimbustech.co.kr/privkey.pem
</VirtualHost>
</IfModule>
